---
const chapter = Astro.locals.chapter;
const pathname = Astro.url.pathname;

function isActive(path: string) {
  if (path === "/") return pathname === "/";
  return pathname.startsWith(path);
}
---

<nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="container mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <span class="text-xl font-bold text-ah-dark">
        {chapter.name.replace("BNI", "").trim()} <span class="text-ah-red">BNI</span>
      </span>
    </a>
    <div class="hidden md:flex items-center gap-8">
      <a
        href="/"
        class:list={["text-sm font-medium transition-colors", isActive("/") ? "text-ah-red" : "text-ah-dark hover:text-ah-red"]}
      >
        Home
      </a>
      <a
        href="/members"
        class:list={["text-sm font-medium transition-colors", isActive("/members") ? "text-ah-red" : "text-ah-dark hover:text-ah-red"]}
      >
        Members
      </a>
      <a
        href="/visit"
        class="bg-ah-red text-white px-5 py-2 rounded text-sm font-semibold hover:bg-ah-red-dark transition-colors"
      >
        Visit Us
      </a>
    </div>
    <div class="md:hidden">
      <a
        href="/visit"
        class="bg-ah-red text-white px-4 py-2 rounded text-sm font-semibold hover:bg-ah-red-dark transition-colors"
      >
        Visit Us
      </a>
    </div>
  </div>
</nav>
