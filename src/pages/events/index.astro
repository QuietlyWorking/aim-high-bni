---
import Base from "@/layouts/Base.astro";
import { Icon } from "astro-icon/components";
import { fetchPublicEvents, fetchPastEventRecapPhotos } from "@/lib/supabase";

const chapter = Astro.locals.chapter;
const sb = Astro.locals.supabase;
const events = await fetchPublicEvents(sb, chapter.id);

// For recurring events, fetch recap photos from past instances
const recapPhotoMap = new Map<string, string[]>();
const parentIds = new Set(events.map(e => e.recurrence_parent_id).filter(Boolean) as string[]);
for (const pid of parentIds) {
  const photos = await fetchPastEventRecapPhotos(sb, chapter.id, pid);
  if (photos.length > 0) recapPhotoMap.set(pid, photos);
}

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + "T12:00:00");
  return d.toLocaleDateString("en-US", { weekday: "long", month: "long", day: "numeric", year: "numeric" });
}

function formatTime(t: string): string {
  const parts = t.split(":");
  let hours = parseInt(parts[0], 10);
  const minutes = parts[1] || "00";
  const ampm = hours >= 12 ? "PM" : "AM";
  if (hours > 12) hours -= 12;
  if (hours === 0) hours = 12;
  return `${hours}:${minutes} ${ampm}`;
}

const typeIcons: Record<string, string> = {
  social: "lucide:coffee",
  workshop: "lucide:graduation-cap",
  networking: "lucide:users",
  fundraiser: "lucide:heart",
  meeting: "lucide:calendar",
};

const formatLabels: Record<string, string> = {
  in_person: "In Person",
  virtual: "Virtual",
  hybrid: "Hybrid",
};
---

<Base
  title="Events"
  description={`Upcoming events from ${chapter.name}. Socials, workshops, and networking events open to the community.`}
>

  <!-- Hero -->
  <section class="bg-ah-dark text-white py-16 md:py-20">
    <div class="container mx-auto px-4 text-center max-w-3xl">
      <p class="text-ah-red text-sm uppercase tracking-wider font-medium mb-3">Get Involved</p>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">
        Upcoming Events
      </h1>
      <p class="text-gray-400">
        Beyond our weekly meetings, we host socials, workshops, and community events.
        Everyone's welcome.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="container mx-auto px-4 max-w-5xl">

      {events.length > 0 ? (
        <div class="space-y-12">
          {events.map((event, idx) => {
            const iconName = typeIcons[event.event_type] || "lucide:calendar";
            const imageRight = idx % 2 === 0;

            // Determine best image: hero > gallery[0] > recap photos
            const heroImg = event.image_url;
            const galleryImgs = event.image_urls || [];
            const recapImgs = event.recurrence_parent_id
              ? recapPhotoMap.get(event.recurrence_parent_id) || []
              : [];
            // Collect all photos: hero, gallery, recap from this event, recap from series
            const allPhotos = [
              ...(heroImg ? [heroImg] : []),
              ...galleryImgs,
              ...recapImgs,
            ].filter((v, i, a) => a.indexOf(v) === i); // dedupe
            const hasPhotos = allPhotos.length > 0;
            const hasRecapOnly = !heroImg && galleryImgs.length === 0 && recapImgs.length > 0;

            return (
              <a
                href={`/events/${event.slug}`}
                class:list={[
                  "group block bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden hover:shadow-lg transition-all hover:-translate-y-0.5",
                  hasPhotos ? "md:grid md:grid-cols-2" : "",
                ]}
              >
                {/* Photos — left or right based on zigzag */}
                {hasPhotos && (
                  <div
                    class:list={[
                      "relative overflow-hidden",
                      imageRight ? "md:order-2" : "md:order-1",
                    ]}
                  >
                    {allPhotos.length === 1 ? (
                      <img
                        src={allPhotos[0]}
                        alt={event.name}
                        class="w-full h-48 md:h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        loading="lazy"
                      />
                    ) : allPhotos.length === 2 ? (
                      <div class="grid grid-cols-2 h-48 md:h-full">
                        {allPhotos.slice(0, 2).map((url) => (
                          <img src={url} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                        ))}
                      </div>
                    ) : (
                      <div class="grid grid-cols-2 grid-rows-2 h-48 md:h-full">
                        <img src={allPhotos[0]} alt="" class="w-full h-full object-cover row-span-2 group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                        <img src={allPhotos[1]} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                        {allPhotos.length === 3 ? (
                          <img src={allPhotos[2]} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                        ) : (
                          <div class="relative">
                            <img src={allPhotos[2]} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                            {allPhotos.length > 3 && (
                              <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
                                <span class="text-white font-bold text-lg">+{allPhotos.length - 3}</span>
                              </div>
                            )}
                          </div>
                        )}
                      </div>
                    )}
                    {hasRecapOnly && (
                      <span class="absolute bottom-2 left-2 bg-black/60 text-white text-[10px] font-medium px-2 py-0.5 rounded-full">
                        From a past event
                      </span>
                    )}
                  </div>
                )}

                {/* Content */}
                <div
                  class:list={[
                    "p-6 md:p-8 flex flex-col justify-center",
                    hasPhotos ? (imageRight ? "md:order-1" : "md:order-2") : "",
                  ]}
                >
                  <div class="flex items-center gap-3 mb-3">
                    {/* Date badge */}
                    <div class="flex-shrink-0 w-14 h-14 bg-ah-red/10 rounded-lg flex flex-col items-center justify-center">
                      <span class="text-xs text-ah-red font-medium uppercase">
                        {new Date(event.event_date + "T12:00:00").toLocaleDateString("en-US", { month: "short" })}
                      </span>
                      <span class="text-xl font-bold text-ah-red leading-none">
                        {new Date(event.event_date + "T12:00:00").getDate()}
                      </span>
                    </div>
                    <div>
                      <h2 class="text-xl font-bold text-ah-dark group-hover:text-ah-red transition-colors">{event.name}</h2>
                      <div class="flex gap-2 mt-0.5">
                        <span class="inline-flex items-center gap-1 text-xs font-medium text-ah-gray-text bg-ah-gray px-2 py-0.5 rounded-full">
                          <Icon name={iconName} class="w-3 h-3" />
                          {event.event_type.charAt(0).toUpperCase() + event.event_type.slice(1)}
                        </span>
                        <span class="text-xs font-medium text-ah-gray-text bg-ah-gray px-2 py-0.5 rounded-full">
                          {formatLabels[event.format] || event.format}
                        </span>
                      </div>
                    </div>
                  </div>

                  <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-ah-gray-text mb-3">
                    <span class="flex items-center gap-1">
                      <Icon name="lucide:clock" class="w-3.5 h-3.5" />
                      {formatTime(event.start_time)}{event.end_time ? ` – ${formatTime(event.end_time)}` : ""}
                    </span>
                    {event.location_name && (
                      <span class="flex items-center gap-1">
                        <Icon name="lucide:map-pin" class="w-3.5 h-3.5" />
                        {event.location_name}
                      </span>
                    )}
                  </div>

                  {event.description && (
                    <p class="text-sm text-ah-gray-text leading-relaxed mb-4">{event.description}</p>
                  )}

                  <span class="inline-flex items-center gap-1 text-sm text-ah-red font-medium group-hover:underline">
                    View details <Icon name="lucide:arrow-right" class="w-4 h-4" />
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-16">
          <Icon name="lucide:calendar-x" class="w-12 h-12 text-gray-300 mx-auto mb-4" />
          <h2 class="text-xl font-bold text-ah-dark mb-2">No upcoming events</h2>
          <p class="text-ah-gray-text max-w-md mx-auto mb-8">
            We don't have any public events scheduled right now, but we meet every {chapter.meetingDay} at {chapter.meetingTime}.
          </p>
          <a
            href="/visit"
            class="inline-flex items-center gap-2 bg-ah-red text-white px-6 py-3 rounded-lg font-semibold hover:bg-ah-red-dark transition-colors"
          >
            Visit a Meeting <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </div>
      )}

    </div>
  </section>

  <!-- Weekly meeting CTA -->
  <section class="py-12 bg-ah-gray">
    <div class="container mx-auto px-4 text-center">
      <p class="text-ah-gray-text text-sm mb-3">Looking for our weekly meeting?</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="/meeting"
          class="inline-flex items-center gap-2 text-ah-red font-medium hover:underline"
        >
          What to expect <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
        <span class="text-gray-300">|</span>
        <a
          href="/visit"
          class="inline-flex items-center gap-2 bg-ah-red text-white px-5 py-2 rounded-lg text-sm font-semibold hover:bg-ah-red-dark transition-colors"
        >
          Register to Visit
        </a>
      </div>
    </div>
  </section>

</Base>
