---
import Base from "@/layouts/Base.astro";
import { Icon } from "astro-icon/components";
import { fetchMembers, fetchMember } from "@/lib/supabase";
import RsvpForm from "@/components/react/RsvpForm";

const chapter = Astro.locals.chapter;
const sb = Astro.locals.supabase;
const ref = Astro.url.searchParams.get("ref");
const [members, referrer] = await Promise.all([
  fetchMembers(sb, chapter.id),
  ref ? fetchMember(sb, chapter.id, ref) : Promise.resolve(null),
]);

const steps = [
  { title: "Open Networking", desc: "Casual introductions with members before the structured meeting begins." },
  { title: "Member Presentations", desc: "Each member gives a 60-second overview of their business and ideal referral." },
  { title: "Featured Speaker", desc: "One member delivers an in-depth 10-minute presentation about their expertise." },
  { title: "Referral Passing", desc: "Watch real referrals being exchanged — this is where the business happens." },
  { title: "Visitor Welcome", desc: "You'll have a chance to introduce yourself and your business to the group." },
];

const mostWantedShort = [
  "Family Law Attorney", "Pest Control", "HVAC",
  "Event Planner", "Photographer", "General Contractor",
  "Fitness Trainer", "Chiropractor",
];
---

<Base title="Visit Us" description={`Visit ${chapter.name} — see firsthand how structured networking generates results. Every ${chapter.meetingDay} at ${chapter.meetingTime}. Free to attend.`}>

  <!-- Hero -->
  <section class="bg-ah-dark text-white py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl">
        {referrer && (
          <div class="flex items-center gap-3 mb-4 bg-white/10 rounded-lg px-4 py-3 inline-flex">
            {referrer.headshot_url && (
              <img src={referrer.headshot_url} alt={referrer.full_name} class="w-10 h-10 rounded-full object-cover" />
            )}
            <p class="text-white font-medium">
              {referrer.first_name} {referrer.last_name} invited you to visit
            </p>
          </div>
        )}
        <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
          Visit {chapter.name}
        </h1>
        <p class="text-gray-300 text-lg mb-6">
          See firsthand how structured networking generates nearly <span class="text-white font-semibold">$2M in closed business</span> for
          our members every year. Your first visit is free.
        </p>
        <div class="flex flex-wrap gap-4 text-sm">
          <div class="flex items-center gap-2 bg-white/10 rounded-lg px-4 py-2">
            <Icon name="lucide:calendar" class="w-4 h-4 text-ah-red" />
            <span>Every {chapter.meetingDay}</span>
          </div>
          <div class="flex items-center gap-2 bg-white/10 rounded-lg px-4 py-2">
            <Icon name="lucide:clock" class="w-4 h-4 text-ah-red" />
            <span>{chapter.meetingTime} PT</span>
          </div>
          <div class="flex items-center gap-2 bg-white/10 rounded-lg px-4 py-2">
            <Icon name="lucide:map-pin" class="w-4 h-4 text-ah-red" />
            <span>{chapter.meetingLocation}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="container mx-auto px-4 py-12 md:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
      <!-- Left: Main content -->
      <div class="lg:col-span-3 space-y-16">

        <!-- What to expect -->
        <section>
          <h2 class="text-2xl font-bold text-ah-dark mb-6">What to expect at your visit</h2>
          <div class="space-y-4">
            {steps.map((step, i) => (
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-8 h-8 bg-ah-red text-white rounded-full flex items-center justify-center text-sm font-bold">
                  {i + 1}
                </div>
                <div>
                  <h3 class="font-semibold text-ah-dark">{step.title}</h3>
                  <p class="text-sm text-ah-gray-text">{step.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Members you'll meet -->
        {members.length > 0 && (
          <section>
            <h2 class="text-2xl font-bold text-ah-dark mb-2">Members You'll Meet</h2>
            <p class="text-ah-gray-text mb-6">
              {members.length} professionals across {new Set(members.map((m) => m.profession_category).filter(Boolean)).size} industries — each one a potential referral partner for your business.
            </p>
            <div class="grid grid-cols-3 md:grid-cols-4 gap-4">
              {members.map((m) => (
                <a href={`/members/${m.slug}`} class="text-center group">
                  <div class="w-16 h-16 mx-auto mb-2 rounded-full overflow-hidden border-2 border-transparent group-hover:border-ah-red transition-colors">
                    {m.headshot_url ? (
                      <img src={m.headshot_url} alt={m.full_name} class="w-full h-full object-cover" loading="lazy" />
                    ) : (
                      <div class="w-full h-full bg-gray-200 flex items-center justify-center text-lg font-bold text-gray-400">
                        {m.first_name?.charAt(0)}
                      </div>
                    )}
                  </div>
                  <div class="text-xs font-medium text-ah-dark group-hover:text-ah-red transition-colors">
                    {m.full_name}
                  </div>
                  {m.profession_category && (
                    <span class="inline-block mt-1 text-[10px] bg-ah-red/10 text-ah-red px-2 py-0.5 rounded-full">
                      {m.profession_category}
                    </span>
                  )}
                </a>
              ))}
            </div>
          </section>
        )}
      </div>

      <!-- Right: Sticky RSVP form -->
      <div class="lg:col-span-2">
        <div class="lg:sticky lg:top-24">
          <RsvpForm
            client:visible
            refSlug={ref || undefined}
            referrerName={referrer ? `${referrer.first_name} ${referrer.last_name}` : undefined}
            orgId={chapter.id}
          />

          <!-- Most Wanted mini-section -->
          <div class="mt-6 bg-ah-gray rounded-xl p-6">
            <h3 class="font-semibold text-ah-dark mb-3 flex items-center gap-2">
              <Icon name="lucide:users" class="w-4 h-4 text-ah-red" />
              We're looking for
            </h3>
            <div class="flex flex-wrap gap-2">
              {mostWantedShort.map((p) => (
                <span class="text-xs bg-white text-ah-dark px-3 py-1 rounded-full border border-gray-200">
                  {p}
                </span>
              ))}
              <span class="text-xs text-ah-red font-medium px-3 py-1">+ 9 more</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

</Base>
