---
import Base from "@/layouts/Base.astro";
---

<Base title="Page Not Found">
  <div class="py-24 text-center">
    <div class="container mx-auto px-4">
      <h1 class="text-6xl font-bold text-ah-red mb-4">404</h1>
      <p class="text-xl text-ah-dark mb-8">Page not found</p>
      <a
        href="/"
        class="inline-block bg-ah-red text-white px-6 py-3 rounded font-semibold hover:bg-ah-red-dark transition-colors"
      >
        Back to Home
      </a>
    </div>
  </div>
</Base>
